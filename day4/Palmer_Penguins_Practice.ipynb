        "<details>\n",
        "<summary>💡 <b>Hint</b> (click to expand)</summary>\n",
        "\n",
        "```r\n",
        "library(caret)\n",
        "ctrl  <- trainControl(method = \"cv\", number = 5)\n",
        "kgrid <- expand.grid(k = c(3, 5, 7, 9, 11))\n",
        "knn_model <- train(species ~ ., data = train,\n",
        "                   method    = \"knn\",\n",
        "                   trControl = ctrl,\n",
        "                   tuneGrid  = kgrid,\n",
        "                   preProcess = c(\"center\", \"scale\"))\n",
        "print(knn_model)\n",
        "```\n",
